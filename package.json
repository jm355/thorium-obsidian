{
  "name": "obsidian-thorium-reader",
  "version": "1.0.0",
  "description": "Read EPUB ebooks in Obsidian using the Thorium Web reader",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "epub",
    "ebook",
    "thorium",
    "reader"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.0",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
